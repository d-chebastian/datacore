# Copy to .env and fill in — docker compose reads this automatically. Every value here is optional.
GITHUB_USERNAME=d-chebastian
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Only used by the `viewer` service's /api/ask endpoint — see "Cost & abuse protection" in README.md
# before putting `viewer` on the public internet.
SEARCH_RATE_LIMIT_PER_HOUR=10
SEARCH_DAILY_CAP=100
